 #hash((id . "type.numeric-literal-shape")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 233)
       (clause . "NUMBR/NUMBAR lexical form requires contiguous numeric tokens.")
       (status . implemented)
       (code-refs . ("src/lolcode/lexer.rkt" "src/lolcode/parser.rkt"))
