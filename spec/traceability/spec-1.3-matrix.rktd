 #hash((id . "bukkit.mixin-slot-copy-reverse-order")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 849)
       (clause . "Mixin slots are copied in reverse declaration order.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime.rkt" "src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "Mixin application reverses declaration list so earlier mixins win on duplicates, with static snapshot copy semantics after construction and donor effective-visible source-set (including inherited-visible slots/methods); mutable BUKKIT slot values are copied by reference (call-by-sharing)."))
)
