 #hash((id . "io.gimmeh")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 394)
       (clause . "GIMMEH reads input into variable.")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt" "src/lolcode/runtime.rkt"))
