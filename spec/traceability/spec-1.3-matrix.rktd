 #hash((id . "comment.block-obtw-tldr")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 65)
       (clause . "Block comments begin with OBTW and end with TLDR.")
