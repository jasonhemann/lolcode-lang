 #hash((id . "type.cast-yarn-to-number-strictness")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 237)
       (clause . "Casting YARN to numeric types errors on non-numeric forms.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "Runtime enforces strict decimal numeric lexical forms for YARN->number coercion; NUMBAR->NUMBR truncates toward zero."))
 #hash((id . "type.noob-numeric-op-errors")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 223)
       (clause . "NOOB cannot be used in typed operations like numeric math; such use errors.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/value.rkt" "src/lolcode/runtime/operators.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "Arithmetic coercion rejects NOOB in numeric contexts rather than treating it as zero."))
 #hash((id . "type.numbar-yarn-print-default-precision")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 235)
       (clause . "Casting/printing NUMBAR as YARN defaults to two decimal places.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "NUMBAR->YARN printing truncates to a default maximum of two decimal places (no forced zero-padding); because 1.3 defines no precision-control surface, default precision is treated as the only mode."))
 #hash((id . "type.primitives-immutable")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 166)
       (clause . "Primitive values are immutable; built-ins return new values.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/operators.rkt" "src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "Arithmetic and string concatenation do not mutate source bindings; reassignment is explicit via R/IS NOW A. The singleton part of the clause is semantically sharp only for WIN/FAIL/NOOB; numeric/string representation identity remains implementation-level and non-observable under strict equality semantics."))
 #hash((id . "op.an-optional-binary")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 277)
       (clause . "Binary operator syntax uses optional [AN] separator.")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt" "tests/spec/parse-negative-test.rkt" "tests/spec/spec-audit/edge-cases-test.rkt"))
       (notes . "Grammar supports both canonical and omitted-AN forms across full binary operator family; non-spec separator token AND is rejected."))
 #hash((id . "op.mkay-variadic-form")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 286)
       (clause . "Variadics use MKAY terminator with optional AN separators between args.")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt" "tests/spec/spec-audit/edge-cases-test.rkt" "tests/spec/spec-audit/regression-canary-test.rkt"))
       (notes . "Parser accepts explicit MKAY and line-terminated closure for open variadics (ALL OF/ANY OF), but rejects implicit omission before continued same-statement tails (for example before `!` or `AN YR`). Runtime policy pins left-to-right evaluation with short-circuit behavior for ALL OF/ANY OF (stop at first decisive operand)."))
 #hash((id . "op.strict-canonical-spellings")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 289)
       (clause . "Operators are spelled as listed in spec (e.g., DIFF OF, QUOSHUNT OF).")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt"))
       (test-refs . ("tests/spec/parse-negative-test.rkt" "tests/spec/spec-audit/edge-cases-test.rkt"))
       (notes . "Non-spec aliases are not tokenized as operator keywords."))
 #hash((id . "op.math-numbr-vs-numbar-mode")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 305)
       (clause . "Math uses integer mode for NUMBR/NUMBR and floating mode when either operand is NUMBAR.")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/operators.rkt" "src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "QUOSHUNT and other math operators use integer arithmetic when both coerced operands are exact integers; if either operand is NUMBAR/inexact, floating arithmetic is used and printed with NUMBAR YARN formatting rules."))
 #hash((id . "op.comparison-equality-semantics")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 335)
       (clause . "Equality compares numerically for NUMBR/NUMBAR operands; otherwise no implicit cast (e.g. \"3\" vs 3 is FAIL).")
       (status . implemented)
       (code-refs . ("src/lolcode/runtime/operators.rkt" "src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt"))
       (notes . "BOTH SAEM/DIFFRINT use spec-aware equality: numeric mode only when both operands are numeric; non-numeric forms compare without implicit coercion and preserve host identity behavior for object/function values."))
 #hash((id . "op.smoosh")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 356)
       (clause . "SMOOSH concatenation supports optional AN and optional MKAY closure by line ending.")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt" "src/lolcode/runtime/operators.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt" "tests/spec/spec-audit/edge-cases-test.rkt"))
       (notes . "SMOOSH forms with and without AN/MKAY are exercised in runtime tests. Strict arity policy is one-or-more arguments (zero-arg parse rejection; one-arg identity accepted), with eager left-to-right operand evaluation preserving side effects from earlier operands when later operands error."))
 #hash((id . "cast.maek")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 362)
       (clause . "MAEK expression cast operator.")
       (status . implemented)
       (code-refs . ("src/lolcode/parser.rkt" "src/lolcode/runtime.rkt" "src/lolcode/runtime/value.rkt"))
       (test-refs . ("tests/spec/runtime-core-test.rkt" "tests/spec/parse-negative-test.rkt"))
       (notes . "MAEK compiles through cast-value with explicit conversion semantics; optional [A] token is supported only for MAEK forms; cast target designators are restricted to TROOF/YARN/NUMBR/NUMBAR/NOOB with strict-case spelling; MAEK is non-mutating and leaves source bindings/slots unchanged."))
 #hash((id . "cast.is-now-a")
