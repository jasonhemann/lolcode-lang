 #hash((id . "flow.expr-stmt-it-local-scope")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 407)
       (clause . "Bare expression statements update IT; IT remains local until replaced by the next bare expression.")
