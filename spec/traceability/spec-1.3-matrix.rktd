       (notes . "IS NOW A updates only the assignment target; cast target designators are restricted to TROOF/YARN/NUMBR/NUMBAR/NOOB with strict-case spelling."))
 #hash((id . "io.visible")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 383)
       (clause . "VISIBLE prints concatenated argument YARNs; ! suppresses newline.")
