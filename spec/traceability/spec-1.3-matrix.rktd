       (code-refs . ("src/lolcode/parser.rkt"))
       (test-refs . ("tests/spec/parse-negative-test.rkt"))
       (notes . "Parser enforces variable/lvalue target shape for both R assignment and IS NOW A cast-assignment statements; non-variable LHS expressions are rejected at parse time."))
