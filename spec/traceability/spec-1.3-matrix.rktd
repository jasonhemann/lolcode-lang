 #hash((id . "var.scope-adjudication-main-vs-object")
       (spec-version . "1.3")
       (source-file . "spec/upstream/lolcode-spec-v1.3.md")
       (source-line . 105)
       (clause . "Scope text says local main/function scope and no global scope.")
       (status . implemented)
